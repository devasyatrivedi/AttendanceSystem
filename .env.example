# ---- Database (use ONE of the two options) ----
# Option 1: Neon / Render (cloud) — single connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Option 2: Local PostgreSQL — individual variables (used if DATABASE_URL is not set)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=attendance_db
# DB_USER=postgres
# DB_PASSWORD=your_password

# ---- Auth ----
JWT_SECRET=your_jwt_secret_here

# ---- Email (Gmail App Password) ----
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password

# ---- Python (local face recognition only) ----
PYTHON_PATH=python

# ---- Server ----
PORT=3000
